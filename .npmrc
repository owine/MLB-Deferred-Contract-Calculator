# Supply-chain hardening.
#
# - save-exact: any future `pnpm add foo` writes an exact pin to
#   package.json, never a caret range.
# - engine-strict: `pnpm install` fails if the local Node differs from
#   package.json's `engines.node`, preventing accidental runtime drift.
# - ignore-scripts: block lifecycle scripts (preinstall/install/postinstall)
#   on dependencies. Stops the most common npm-supply-chain RCE vector
#   (typosquats and compromised packages that ship malicious install hooks).
#   pnpm 11 also gates build scripts behind the pnpm-workspace.yaml
#   `allowBuilds` allowlist; this keeps the explicit policy for both tools.
# - fund=false / audit=false: keep output quiet in CI; the audit runs
#   explicitly in .github/workflows/ci.yml.
#
# The pnpm-only knobs (preferFrozenLockfile, allowBuilds) live in
# pnpm-workspace.yaml, not here: npm reads this .npmrc too and warns
# "Unknown config" on keys it doesn't recognize. Every key below is a valid
# npm setting that pnpm also honors, so both tools stay quiet.
save-exact=true
engine-strict=true
ignore-scripts=true
fund=false
audit=false
